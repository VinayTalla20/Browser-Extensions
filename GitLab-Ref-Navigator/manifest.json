{
  "manifest_version": 3,
  "name": "GitLab Ref Navigator",
  "version": "1.0.0",
  "description": "Makes include file references in GitLab CI YAML files clickable — navigate to referenced pipelines, configs, and templates in one click.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://gitlab.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gitlab.com/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitLab Ref Navigator"
  }
}